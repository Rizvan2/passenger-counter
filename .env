SERVER_PORT=8081
JAVA_OPTS=-Xms256m -Xmx2g

PC_MODELS_DIR=./models
PC_VIDEOS_DIR=./videos

# Автозапуск анализа при появлении ролика в videos/{deviceId}/{YYYY-MM-DD}/
PC_LOCAL_INGEST_ENABLED=true
PC_LOCAL_INGEST_SCAN_INTERVAL_MS=15000

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/passenger_counter
SPRING_DATASOURCE_USERNAME=passenger_counter
SPRING_DATASOURCE_PASSWORD=passenger_counter
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update

ANALYSIS_RESULTS_PERSISTENCE_ENABLED=true
